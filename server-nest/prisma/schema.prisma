generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 租户/品牌方
// ============================================================
model Tenant {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  name      String   @db.VarChar(120)
  phone     String?  @db.VarChar(32)
  planType  PlanType @default(free)
  status    TenantStatus @default(trial)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  expiredAt DateTime? @map("expired_at")

  venues            Venue[]
  appUsers          AppUser[]
  subscriptions     SubscriptionPlan[]
  players           Player[]
  coupons           Coupon[]
  orders            Order[]

  @@map("tenants")
}

enum PlanType {
  free
  basic
  pro
  enterprise
}

enum TenantStatus {
  trial
  active
  suspended
  expired
}

// ============================================================
// 订阅方案
// ============================================================
model SubscriptionPlan {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  tenantId        Int      @map("tenant_id") @db.UnsignedInt
  name            String   @db.VarChar(64)
  pricePerMonth   Int      @map("price_per_month") @db.UnsignedInt
  maxVenues       Int      @map("max_venues") @db.UnsignedInt
  maxStaff        Int      @map("max_staff") @db.UnsignedInt
  maxTables       Int      @map("max_tables") @db.UnsignedInt
  features        Json     @db.Json
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscription_plans")
}

// ============================================================
// 门店/场地
// ============================================================
model Venue {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  tenantId  Int      @default(1) @map("tenant_id") @db.UnsignedInt
  name      String   @db.VarChar(120)
  address   String?  @db.VarChar(255)
  logoUrl   String?  @map("logo_url") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tables GameTable[]
  orders Order[]

  @@unique([tenantId, name])
  @@map("venues")
}

// ============================================================
// 员工档案
// ============================================================
model StaffProfile {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  employeeNo String   @unique @map("employee_no") @db.VarChar(32)
  fullName   String   @map("full_name") @db.VarChar(100)
  phone      String?  @db.VarChar(32)
  position   String   @default("店员") @db.VarChar(64)
  status     StaffStatus @default(active)
  hiredAt    DateTime? @map("hired_at") @db.Date
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  appUser AppUser?

  @@map("staff_profiles")
}

enum StaffStatus {
  active
  disabled
}

// ============================================================
// 后台登录账号
// ============================================================
model AppUser {
  id           Int      @id @default(autoincrement()) @db.UnsignedInt
  tenantId     Int      @default(1) @map("tenant_id") @db.UnsignedInt
  staffId      Int?     @unique @map("staff_id") @db.UnsignedInt
  username     String   @db.VarChar(64)
  displayName  String   @map("display_name") @db.VarChar(100)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(staff)
  status       UserStatus @default(active)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff        StaffProfile? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  authSessions AuthSession[]
  auditLogs    AuditLog[]

  @@unique([tenantId, username])
  @@map("app_users")
}

enum UserRole {
  admin
  staff
}

enum UserStatus {
  active
  disabled
}

// ============================================================
// 后台登录会话
// ============================================================
model AuthSession {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId    Int      @map("user_id") @db.UnsignedInt
  tokenHash String   @unique @map("token_hash") @db.Char(64)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

// ============================================================
// 操作审计日志
// ============================================================
model AuditLog {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  tenantId        Int?     @map("tenant_id") @db.UnsignedInt
  userId          Int?     @map("user_id") @db.UnsignedInt
  action          String   @db.VarChar(120)
  resourceType    String   @map("resource_type") @db.VarChar(64)
  resourceId      String?  @map("resource_id") @db.VarChar(64)
  requestMethod   String   @map("request_method") @db.VarChar(10)
  requestPath     String   @map("request_path") @db.VarChar(255)
  statusCode      Int      @map("status_code") @db.SmallInt
  ip              String?  @db.VarChar(64)
  userAgent       String?  @map("user_agent") @db.VarChar(255)
  requestBodyJson Json?    @map("request_body_json")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  user AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// 桌游目录
// ============================================================
model Game {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  title           String   @unique @db.VarChar(160)
  coverImageUrl   String?  @map("cover_image_url") @db.VarChar(512)
  rulesPdfUrl     String?  @map("rules_pdf_url") @db.VarChar(512)
  minPlayers      Int      @default(2) @map("min_players") @db.UnsignedTinyInt
  maxPlayers      Int      @default(6) @map("max_players") @db.UnsignedTinyInt
  category        String   @default("综合") @db.VarChar(32)
  difficultyLevel Int      @default(3) @map("difficulty_level") @db.UnsignedTinyInt
  avgMinutes      Int      @default(90) @map("avg_minutes") @db.UnsignedSmallInt
  recommendWeight Decimal  @default(1.00) @map("recommend_weight") @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  gameRecords GameRecord[]

  @@map("games")
}

// ============================================================
// 游戏桌
// ============================================================
model GameTable {
  id            Int      @id @default(autoincrement()) @db.UnsignedInt
  venueId       Int      @map("venue_id") @db.UnsignedInt
  code          String   @db.VarChar(16)
  posX          Int      @default(0) @map("pos_x") @db.SmallInt
  posY          Int      @default(0) @map("pos_y") @db.SmallInt
  sortOrder     Int      @default(0) @map("sort_order") @db.SmallInt
  seatCapacity  Int      @default(4) @map("seat_capacity") @db.UnsignedTinyInt
  areaType      String   @default("standard") @map("area_type") @db.VarChar(24)
  floorPhotoUrl String?  @map("floor_photo_url") @db.VarChar(512)

  venue        Venue            @relation(fields: [venueId], references: [id])
  tableState   GameTableState?
  reservations Reservation[]
  playSessions PlaySession[]

  @@unique([venueId, code])
  @@map("game_tables")
}

// ============================================================
// 桌位运行态
// ============================================================
model GameTableState {
  tableId              Int      @id @map("table_id") @db.UnsignedInt
  status               TableStatus @default(idle)
  currentReservationId Int?     @map("current_reservation_id") @db.UnsignedInt
  currentSessionId     Int?     @map("current_session_id") @db.UnsignedInt
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  table GameTable @relation(fields: [tableId], references: [id])

  @@map("game_table_state")
}

enum TableStatus {
  idle
  reserved
  occupied
}

// ============================================================
// 玩家/会员
// ============================================================
model Player {
  id                 Int      @id @default(autoincrement()) @db.UnsignedInt
  tenantId           Int      @default(1) @map("tenant_id") @db.UnsignedInt
  memberNo           String?  @unique @map("member_no") @db.VarChar(32)
  displayName        String   @map("display_name") @db.VarChar(100)
  phone              String?  @db.VarChar(32)
  avatarUrl          String?  @map("avatar_url") @db.VarChar(512)
  balanceCents       Int      @default(0) @map("balance_cents") @db.UnsignedInt
  totalRechargedCents Int     @default(0) @map("total_recharged_cents") @db.UnsignedInt
  totalSpentCents    Int      @default(0) @map("total_spent_cents") @db.UnsignedInt
  membershipLevel    MembershipLevel @default(bronze)
  points             Int      @default(0) @db.UnsignedInt
  birthday           DateTime? @db.Date
  status             PlayerStatus @default(active)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  playerStats  PlayerStat?
  reservations Reservation[]
  gameRecords  GameRecord[]
  pointsLogs   PointsLog[]
  memberCoupons MemberCoupon[]
  orders       Order[]

  @@unique([tenantId, memberNo])
  @@index([tenantId, status])
  @@map("players")
}

enum MembershipLevel {
  bronze   // 注册
  silver   // 500元
  gold     // 2000元
  platinum // 5000元
  diamond  // 10000元
}

enum PlayerStatus {
  active
  disabled
}

// ============================================================
// 积分流水
// ============================================================
model PointsLog {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  playerId    Int      @map("player_id") @db.UnsignedInt
  tenantId    Int      @map("tenant_id") @db.UnsignedInt
  points      Int      @db.Int  // 可正可负
  description String   @db.VarChar(255)
  type        PointsLogType @map("type")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@index([tenantId, createdAt])
  @@map("points_logs")
}

enum PointsLogType {
  consume    // 消费得积分
  sign_in    // 签到
  redeem     // 兑换（扣积分）
  admin      // 手工调整
}

// ============================================================
// 战绩聚合
// ============================================================
model PlayerStat {
  playerId  Int       @id @map("player_id") @db.UnsignedInt
  wins      Int       @default(0) @db.UnsignedInt
  games     Int       @default(0) @db.UnsignedInt
  lastWinAt DateTime? @map("last_win_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_stats")
}

// ============================================================
// 预约
// ============================================================
model Reservation {
  id            Int              @id @default(autoincrement()) @db.UnsignedInt
  tableId       Int              @map("table_id") @db.UnsignedInt
  playerId      Int?             @map("player_id") @db.UnsignedInt
  guestName     String           @map("guest_name") @db.VarChar(100)
  guestPhone    String?          @map("guest_phone") @db.VarChar(30)
  partySize     Int              @default(1) @map("party_size") @db.UnsignedInt
  reservedStart DateTime         @map("reserved_start")
  reservedEnd   DateTime         @map("reserved_end")
  status        ReservationStatus @default(pending)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamp(0)

  table        GameTable      @relation(fields: [tableId], references: [id])
  player       Player?        @relation(fields: [playerId], references: [id])
  playSessions PlaySession[]

  @@index([tableId, status, reservedStart, reservedEnd])
  @@index([playerId])
  @@index([createdAt])
  @@map("reservations")
}

enum ReservationStatus {
  pending
  active
  cancelled
  completed
  no_show
}

// ============================================================
// 开台对局与计费
// ============================================================
model PlaySession {
  id            Int       @id @default(autoincrement()) @db.UnsignedInt
  tableId       Int       @map("table_id") @db.UnsignedInt
  reservationId Int?      @map("reservation_id") @db.UnsignedInt
  guestName     String?   @map("guest_name") @db.VarChar(100)
  guestPhone    String?   @map("guest_phone") @db.VarChar(30)
  partySize     Int       @default(1) @map("party_size") @db.UnsignedInt
  startedAt     DateTime  @map("started_at")
  endedAt       DateTime? @map("ended_at")
  billedMinutes Int?      @map("billed_minutes") @db.UnsignedInt
  amountCents   Int       @default(0) @map("amount_cents") @db.UnsignedInt
  notes         String?   @db.VarChar(500)

  table        GameTable     @relation(fields: [tableId], references: [id])
  reservation  Reservation?  @relation(fields: [reservationId], references: [id])
  gameRecords  GameRecord[]

  @@index([tableId, startedAt])
  @@index([endedAt])
  @@index([reservationId])
  @@map("play_sessions")
}

// ============================================================
// 单局战绩
// ============================================================
model GameRecord {
  id                Int      @id @default(autoincrement()) @db.UnsignedInt
  sessionId         Int      @map("session_id") @db.UnsignedInt
  gameId            Int      @map("game_id") @db.UnsignedInt
  titleSnapshot     String   @map("title_snapshot") @db.VarChar(160)
  winnerPlayerId    Int?     @map("winner_player_id") @db.UnsignedInt
  winnerDisplayName String?  @map("winner_display_name") @db.VarChar(100)
  scoreJson         Json?    @map("score_json")
  playedAt          DateTime @default(now()) @map("played_at")

  session  PlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  game     Game        @relation(fields: [gameId], references: [id])
  winner   Player?     @relation(fields: [winnerPlayerId], references: [id])

  @@index([sessionId])
  @@index([gameId, playedAt])
  @@index([winnerPlayerId])
  @@map("game_records")
}

// ============================================================
// 优惠券
// ============================================================
model Coupon {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  tenantId    Int      @map("tenant_id") @db.UnsignedInt
  name        String   @db.VarChar(120)
  type        CouponType
  value       Int      @db.UnsignedInt  // 单位: 分（满减/折扣）
  minAmount   Int      @default(0) @map("min_amount") @db.UnsignedInt  // 满X分才能用
  totalQty    Int      @map("total_qty") @db.UnsignedInt  // 总量
  usedQty     Int      @default(0) @map("used_qty") @db.UnsignedInt
  startAt     DateTime @map("start_at")
  endAt       DateTime @map("end_at")
  validOn     CouponValidOn @map("valid_on")  // 工作日/周末/全时段
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberCoupons   MemberCoupon[]

  @@unique([tenantId, name])
  @@index([tenantId, endAt])
  @@map("coupons")
}

enum CouponType {
  discount_fixed  // 满减 (满100减10)
  discount_percent // 折扣 (8折)
  newbie          // 新人券
}

enum CouponValidOn {
  weekday
  weekend
  all
}

enum MemberCouponStatus {
  unused
  used
  expired
}

// ============================================================
// 会员领券
// ============================================================
model MemberCoupon {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  playerId  Int      @map("player_id") @db.UnsignedInt
  couponId  Int      @map("coupon_id") @db.UnsignedInt
  status    MemberCouponStatus @default(unused)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([playerId, couponId])
  @@index([playerId, status])
  @@index([couponId, status])
  @@map("member_coupons")
}

// ============================================================
// 订单
// ============================================================
model Order {
  id            Int      @id @default(autoincrement()) @db.UnsignedInt
  tenantId      Int      @map("tenant_id") @db.UnsignedInt
  venueId       Int      @map("venue_id") @db.UnsignedInt
  playerId      Int?     @map("player_id") @db.UnsignedInt
  orderNo       String   @unique @map("order_no") @db.VarChar(64)
  amountCents   Int      @map("amount_cents") @db.UnsignedInt
  discountCents Int      @default(0) @map("discount_cents") @db.UnsignedInt
  finalCents    Int      @map("final_cents") @db.UnsignedInt  // 实际支付
  status        OrderStatus @default(pending)
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  venue    Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  player   Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@unique([tenantId, orderNo])
  @@index([tenantId, createdAt])
  @@index([venueId, createdAt])
  @@index([playerId, createdAt])
  @@map("orders")
}

enum OrderStatus {
  pending     // 待支付
  paid        // 已支付
  cancelled   // 已取消
  refunded    // 已退款
}

// ============================================================
// 订单明细
// ============================================================
model OrderItem {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  orderId     Int      @map("order_id") @db.UnsignedInt
  sessionId   Int?     @map("session_id") @db.UnsignedInt  // 开台记录
  gameId      Int?     @map("game_id") @db.UnsignedInt
  description String   @db.VarChar(255)
  quantity    Int      @default(1) @db.UnsignedInt
  unitPrice   Int      @map("unit_price") @db.UnsignedInt  // 单位: 分
  totalPrice  Int      @map("total_price") @db.UnsignedInt

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}
