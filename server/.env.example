PORT=8788
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=boardgame
DB_PASSWORD=boardgame
DB_NAME=boardgame
RESERVATION_GRACE_MINUTES=15
ALLOW_PUBLIC_REGISTER=1
SERVE_WEB=1

# LLM 大模型（OpenAI 兼容接口）。留空则走演示占位回答。
# 支持通义千问/DeepSeek/Moonshot/智谱等任意 OpenAI 兼容服务，改 BASE_URL 和 MODEL 即可。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 生产部署：见 deploy/docker-compose.yml 与 docs/数据库实施与维护计划.md
