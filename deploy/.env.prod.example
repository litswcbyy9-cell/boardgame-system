# 生产环境变量模板 —— 复制为 .env.prod 后填真实值，切勿提交 .env.prod
# 用法：cp deploy/.env.prod.example deploy/.env.prod && vi deploy/.env.prod

# 你的域名（已解析到本服务器公网 IP）
SITE_DOMAIN=bg.example.com

# MySQL 密码（请改成强随机串，勿用默认值）
MYSQL_ROOT_PASSWORD=change-me-root-strong
MYSQL_PASSWORD=change-me-app-strong

# DeepSeek / OpenAI 兼容大模型
OPENAI_API_KEY=sk-你的DeepSeekKey
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
